# ============================================================
# English Web — Root Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=englishweb
POSTGRES_PASSWORD=changeme_in_production

# Per-service DB names (auto-created via init scripts)
AUTH_DB_NAME=englishweb_auth
USER_DB_NAME=englishweb_users
CONTENT_DB_NAME=englishweb_content
AI_DB_NAME=englishweb_ai
GAMIFICATION_DB_NAME=englishweb_gamification

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# --- JWT ---
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-chars
JWT_ACCESS_TTL=900        # 15 minutes in seconds
JWT_REFRESH_TTL=604800    # 7 days in seconds

# --- Service Ports ---
API_GATEWAY_PORT=3001
AUTH_SERVICE_PORT=4001
USER_SERVICE_PORT=4002
CONTENT_SERVICE_PORT=4003
AI_SERVICE_PORT=4004
GAMIFICATION_SERVICE_PORT=4005

# --- Web App ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-nextauth-secret

# --- AI Providers (system-level defaults) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# User-supplied keys are stored encrypted in DB, not here

# --- MinIO (Object Storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_ASSETS=english-web-assets
MINIO_USE_SSL=false

# --- Internal Service Auth ---
INTERNAL_SERVICE_SECRET=change-me-internal-service-secret

# --- Encryption (for user AI keys at rest) ---
ENCRYPTION_KEY=change-me-32-byte-hex-key-here-xx
